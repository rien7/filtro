{
  "name": "filtro",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.18.3",
  "description": "",
  "author": "",
  "license": "ISC",
  "keywords": [],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./default-theme": {
      "types": "./dist/presets/default-theme/index.d.mts",
      "import": "./dist/presets/default-theme/index.mjs"
    },
    "./nuqs": {
      "types": "./dist/nuqs/index.d.mts",
      "import": "./dist/nuqs/index.mjs"
    },
    "./default-theme.css": "./dist/default-theme.css"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/presets/default-theme/index.tsx src/nuqs/index.ts --format esm --dts && pnpm run build:css",
    "build:css": "node ./scripts/build-default-theme-css.mjs",
    "build:ui": "vite build --config vite.config.ts",
    "dev:ui": "vite --config vite.config.ts",
    "lint": "eslint .",
    "preview:ui": "vite preview --config vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run typecheck"
  },
  "peerDependencies": {
    "nuqs": ">=2.8.9",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "nuqs": {
      "optional": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.3",
    "eslint-config-hyoban": "^7.0.3",
    "lint-staged": "^16.3.3",
    "nuqs": "^2.8.9",
    "react-day-picker": "^9.14.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.20.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
