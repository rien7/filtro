{
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
  },
  "include": ["src"]
}
